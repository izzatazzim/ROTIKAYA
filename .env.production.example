# ===========================================================================
# PRODUCTION ENVIRONMENT TEMPLATE  —  Rotikaya Sales Tracking System
# ===========================================================================
# These are the variables to set in the Railway dashboard
# (project -> service -> Variables). Do NOT commit real values to git.
# Copy each KEY=VALUE below into Railway; fill in the marked placeholders.
# ===========================================================================

# --- Core application -------------------------------------------------------
APP_NAME="Rotikaya Media Sales Tracking System"
APP_ENV=production
# Generate once locally with:  php artisan key:generate --show
# then paste the whole "base64:...." string here. NEVER reuse the dev key.
APP_KEY=
# MUST be false in production (hides stack traces / sensitive errors).
APP_DEBUG=false
# Your live Railway URL, including https://  (set after the first deploy).
APP_URL=https://REPLACE-ME.up.railway.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# --- Logging ----------------------------------------------------------------
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

# --- Database (SQLite on the Railway persistent volume) ---------------------
# The volume is mounted at /data, so the database file survives redeploys.
# The container entrypoint creates this file and runs migrations + one-time seed.
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

# --- If you switch to a Railway managed MySQL instead, use these instead of
#     the two SQLite lines above (values come from the MySQL service):
# DB_CONNECTION=mysql
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

# --- Sessions / cache / queue (all stored in the database) ------------------
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
CACHE_STORE=database
QUEUE_CONNECTION=database
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# --- Mail (log driver: invoices/emails are written to logs, not sent) -------
# Swap to smtp + real credentials only if you want live email delivery.
MAIL_MAILER=log
MAIL_FROM_ADDRESS=hello@rotikaya.com
MAIL_FROM_NAME="Rotikaya Media"

# --- WhatsApp (simulator: no real messages are sent — required for demo) ----
WHATSAPP_DRIVER=simulator
WHATSAPP_SIMULATE_MODE=always_success
WHATSAPP_SIMULATE_FAILURE_RATE=30

# --- Company billing identity (shown on reminders/invoices) -----------------
COMPANY_NAME="Rotikaya Media Sdn Bhd"

# --- Front-end build --------------------------------------------------------
VITE_APP_NAME="${APP_NAME}"
